{
    "domain":[200, 200, 1],
    "boundary":[
        {
            "label":"moving_wall",
            "u":{"type":"fixedValue", "value":[1.0, 0.0, 0.0]},
            "p":{"type":"fixedGradient", "value":0.0},
            "topo":{"io":"outer", "face":"y+"}
        },
        {
            "label":"fixed_wall",
            "u":{"type":"fixedValue", "value":[0.0, 0.0, 0.0]},
            "p":{"type":"fixedGradient", "value":0.0},
            "topo":{"io":"outer", "face":["y-","x-","x+"]}
        },
        {
            "label":"front_back",
            "u":{"type":"symmetric"},
            "p":{"type":"symmetric"},
            "topo":{"io":"outer", "face":["z-","z+"]}
        }
    ],
    "init":{"u":[0.0, 0.0, 0.0], "p":0.0},
    "time":{"dt":5e-3, "t":100.0},
    "flow":{"re":5000, "tdiv":1e-2, "scheme":"muscl", "maxit":1000},
    "poisson":{"solver":"jacobi", "e":1e-4, "maxit":1000}
}