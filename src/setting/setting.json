{
    "domain":[200, 200, 1],
    "boundary":[
        {
            "label":"moving_wall",
            "U":{"type":"fixedValue", "value":[1.0, 0.0, 0.0]},
            "P":{"type":"fixedGradient", "value":0.0},
            "topo":{"io":"outer", "face":["y+"]}
        },
        {
            "label":"fixed_wall",
            "U":{"type":"fixedValue", "value":[0.0, 0.0, 0.0]},
            "P":{"type":"fixedGradient", "value":0.0},
            "topo":{"io":"outer", "face":["x+","x-","y-"]}
        },
        {
            "label":"front_back",
            "U":{"type":"symmetric"},
            "P":{"type":"symmetric"},
            "topo":{"io":"outer", "face":["z+", "z-"]}
        }
    ],
    "init":{"U":[0.0, 0.0, 0.0], "P":0.0},
    "parameter":{"Re":5000, "dt":0.005, "timestep":20000, "TDiv":1e-4},
    "monitor":{"type":"time", "interval":1.0},
    "poisson":{"solver":"sor", "omega":1.2}
}